# ─── LLM ──────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL_MANAGER=llama-3.3-70b-versatile
GROQ_MODEL_SPECIALIST=llama-3.3-70b-versatile
GROQ_MODEL_VALIDATOR=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3

# ─── External integrations ────────────────────────────────────────────
TAVILY_API_KEY=tvly-your_tavily_key_here

# ─── ClickUp (ticket creation via MCP) ────────────────────────────────
# Personal API token: ClickUp → Settings → Apps → API Token (starts with pk_)
CLICKUP_API_KEY=pk_your_clickup_token_here
# Workspace/team id: the workspace that OWNS the List below (must match — if your token can see
# multiple workspaces, the free server only creates in this default one).
CLICKUP_TEAM_ID=
# Default List that new tickets are created in (open the List → ... → Copy ID)
CLICKUP_LIST_ID=
# MCP server launched as a stdio subprocess (needs Node/npx). Pinned to 0.8.5 — the last FREE
# version; newer releases paywall multi-workspace tokens (return a license prompt, create nothing).
CLICKUP_MCP_COMMAND=npx
CLICKUP_MCP_ARGS=-y @taazkareem/clickup-mcp-server@0.8.5

# ─── Database (Neon Postgres) ─────────────────────────────────────────
# Get from https://console.neon.tech → your project → Connection string
# Use the "pooled" connection string for app runtime.
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.region.aws.neon.tech/agencyos?sslmode=require
# Sync URL (Alembic uses sync driver):
DATABASE_URL_SYNC=postgresql+psycopg://user:password@ep-xxx.region.aws.neon.tech/agencyos?sslmode=require

# ─── Observability (optional) ─────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agencyos
LANGSMITH_TRACING=false

# ─── Runtime ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
OUTPUT_DIR=./outputs
MAX_VALIDATOR_RETRIES=3
MAX_TOOL_RETRIES=3
